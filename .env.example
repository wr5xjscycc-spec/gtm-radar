# Copy to .env (gitignored). Real keys never go in the client (P1 puts them in Convex env config).

# --- REQUIRED for v1 ---
OPENAI_API_KEY=            # the grounded answer engine (Responses API + web_search) AND gpt-5-mini enrichment (firmographics understanding card)
# Fiber battlefield + firmographics (LIVE). Set in Convex env too: `npx convex env set FIBER_API_KEY <key>`.
# Drives convex/sourcing.ts buildBattlefield: a parallel multi-angle company-search sweep (api.fiber.ai)
# discovers 20-40 real competitors + kitchen-sink firmographics. Absent -> degrades to the typed-competitor
# thin slice (still works, no battlefield discovery). NOTE: Fiber has no off-page/SEO signals (offpage stays
# honestly flagged missing); "find-similar-companies" is NOT a real endpoint — we build it from company-search.
FIBER_API_KEY=
CONVEX_DEPLOYMENT=
# The deployment URL the edge runner (scripts/enrich-pages.ts) writes to. Get from `npx convex dev` output.
CONVEX_URL=

# --- OPTIONAL / deferred (the build runs OpenAI-only without these) ---
# Extra answer engines — wired the day you have keys; NEVER faked with an OpenAI model.
PERPLEXITY_API_KEY=       # optional: Perplexity Sonar engine
GEMINI_API_KEY=          # optional: Gemini grounded engine
# Later-phase enrichment sources (P3 Phase 2+):
# Orange Slice auth: configure({apiKey}) > ORANGESLICE_API_KEY env > ~/.config/orangeslice/config.json.
# User is already authenticated via config file; key only needed for override.
ORANGESLICE_API_KEY=
SERP_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
ANALYSIS_SERVICE_URL=  # P4 analysis FastAPI (uvicorn). Convex action POST's fit jobs here and polls for completion. Default http://localhost:8000

# Convex client (safe to expose) — the deployment URL the React board connects to.
VITE_CONVEX_URL=

# Auth (P1) — JWT issuer Convex trusts. Set in Convex env, not the client:
#   npx convex env set AUTH_ISSUER_DOMAIN <issuer-url> ; npx convex env set AUTH_APP_ID <app-id>
AUTH_ISSUER_DOMAIN=
AUTH_APP_ID=
