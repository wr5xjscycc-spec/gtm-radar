# Copy to .env (gitignored). Real keys never go in the client (P1 puts them in Convex env config).

# --- REQUIRED for v1 ---
OPENAI_API_KEY=            # the grounded answer engine (Responses API + web_search) AND gpt-4o-mini enrichment
FIBER_API_KEY=            # P3 battlefield sourcing (find-similar-companies)
CONVEX_DEPLOYMENT=

# --- OPTIONAL / deferred (the build runs OpenAI-only without these) ---
# Extra answer engines — wired the day you have keys; NEVER faked with an OpenAI model.
PERPLEXITY_API_KEY=       # optional: Perplexity Sonar engine
GEMINI_API_KEY=          # optional: Gemini grounded engine
# Later-phase enrichment sources (P3 Phase 2+):
ORANGESLICE_API_KEY=
SERP_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
ANALYSIS_SERVICE_URL=

# Convex client (safe to expose) — the deployment URL the React board connects to.
VITE_CONVEX_URL=

# Auth (P1) — JWT issuer Convex trusts. Set in Convex env, not the client:
#   npx convex env set AUTH_ISSUER_DOMAIN <issuer-url> ; npx convex env set AUTH_APP_ID <app-id>
AUTH_ISSUER_DOMAIN=
AUTH_APP_ID=
